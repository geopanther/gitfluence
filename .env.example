# Confluence Production (used on clean default branch, up-to-date with remote)
CONFLUENCE_PROD_HOST=https://atc-int.bmwgroup.net/confluence/rest/api
CONFLUENCE_PROD_TOKEN=

# Confluence Integration (used on feature branches or dirty working trees)
# Falls back to PROD values if not set.
CONFLUENCE_INT_HOST=
CONFLUENCE_INT_TOKEN=

# Confluence Read-Only (optional; all GET requests routed here if set)
CONFLUENCE_READONLY_HOST=
CONFLUENCE_READONLY_TOKEN=

# Confluence Space
CONFLUENCE_SPACE=
