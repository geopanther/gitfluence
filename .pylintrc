# Pylint configuration following Google Python Style Guide
# https://google.github.io/styleguide/pyguide.html

[MAIN]
load-plugins=pylint.extensions.docparams

[MESSAGES CONTROL]
# Disable messages that conflict with black / isort or are too noisy
disable=
    C0114,  # missing-module-docstring
    C0115,  # missing-class-docstring
    C0116,  # missing-function-docstring
    C0301,  # line-too-long (handled by black)
    C0330,  # bad-continuation (handled by black)
    R0903,  # too-few-public-methods
    R0913,  # too-many-arguments
    W0511,  # fixme
    W1203,  # logging-fstring-interpolation

[FORMAT]
max-line-length=88
indent-string='    '

[BASIC]
# Google style: module_name, package_name, ClassName, method_name,
# ExceptionName, function_name, GLOBAL_CONSTANT_NAME, instance_var_name,
# function_parameter_name, local_var_name
good-names=i,j,k,v,e,f,fp,fd,ex,ok,_,log,ctx

module-rgx=[a-z_][a-z0-9_]*$
const-rgx=(([A-Z_][A-Z0-9_]*)|(__.*__)|(_[a-z_]*))$
class-rgx=[A-Z_][a-zA-Z0-9]+$
function-rgx=[a-z_][a-z0-9_]{2,40}$
method-rgx=[a-z_][a-z0-9_]{2,40}$
attr-rgx=[a-z_][a-z0-9_]{2,30}$
argument-rgx=[a-z_][a-z0-9_]{0,30}$
variable-rgx=[a-z_][a-z0-9_]{0,30}$

[DESIGN]
max-args=8
max-locals=20
max-returns=6
max-branches=15
max-statements=60
max-attributes=12

[IMPORTS]
known-third-party=pydantic,pydantic_settings,git,md2cf,requests,atlassian

[TYPECHECK]
# Avoid false positives on pydantic models and md2cf dynamic attributes
ignored-modules=md2cf.document,md2cf.api,md2cf.upsert,md2cf.anchor
ignored-classes=Page,MinimalConfluence
